# =============================================================================
# SoyaLens .gitignore — Configuración de seguridad para GitHub
# =============================================================================

# -----------------------------------------------------------------------------
# ARCHIVOS SENSIBLES — NUNCA SUBIR
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.secret
*.credentials

# -----------------------------------------------------------------------------
# ARCHIVOS MARKDOWN Y AGENTES
# -----------------------------------------------------------------------------
# Ignorar .md auxiliares por defecto
*.md

# Permitir los documentos principales obligatorios para el Hackathon
!README.md
!PROJECT.md

# Permitir markdowns dentro de docs/
!docs/**/*.md
!docs/*.md

# Ignorar directorio de reglas de agentes
.agents/

# Archivos de configuración de agentes IA
.claude.md
.dev_notes.md
AGENTS.md

# -----------------------------------------------------------------------------
# PYTHON / ENTORNO / CACHÉ
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Entornos virtuales (cualquier nombre)
.venv/
venv/
env/
envBwaiBackend/

# -----------------------------------------------------------------------------
# MODELOS IA Y ARCHIVOS PESADOS
# -----------------------------------------------------------------------------
# Pesos de modelos
*.pt
*.pth
*.onnx
*.tflite
*.h5
*.pb
*.safetensors

# Carpeta de pesos entrenados
ai/weights/

# Outputs del entrenamiento (generados por Ultralytics)
runs/

# Cachés de modelos
*.cache

# Dataset de entrenamiento (se descarga de Roboflow, no se sube)
ai/dataset/

# -----------------------------------------------------------------------------
# IMÁGENES Y MEDIA (evitar llenar el repo)
# -----------------------------------------------------------------------------
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.mp4
*.avi
*.mov

# Excepción: imágenes del frontend (iconos, logos, assets)
!frontend/public/**
!frontend/assets/**

# -----------------------------------------------------------------------------
# NODE.JS / FRONTEND (para cuando se configure Next.js)
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# SISTEMA OPERATIVO
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDE / EDITOR
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
*.log
docker-compose.override.yml

# -----------------------------------------------------------------------------
# TEMPORALES
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
