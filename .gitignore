# -----------------------------------------------------------------------------
# ARCHIVOS MARKDOWN Y AGENTES
# -----------------------------------------------------------------------------
# Ignorar todos los markdowns por defecto en la raíz o subcarpetas
*.md

# ¡EXCEPCIONES VITALES!
# Permitir los markdowns dentro de docs/
!docs/**/*.md
!docs/*.md

# Permitir los documentos principales obligatorios para el Hackathon
!README.md
!PROJECT.md

# Ignorar específicamente el directorio de reglas de agentes
.agents/


# -----------------------------------------------------------------------------
# PYTHON / ENTORNO / CACHÉ
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.venv/
venv/
env/
.env

# -----------------------------------------------------------------------------
# MODELOS IA Y ARCHIVOS PESADOS
# -----------------------------------------------------------------------------
# Pesos de modelos (pesados — no subir al repo)
*.pt
*.pth
*.onnx
# Carpeta de pesos entrenados
ai/weights/
# Outputs del entrenamiento (generados por Ultralytics)
runs/
# Cachés generados por Ultralytics
*.cache

# Ignorar fotos de prueba o datasets para no llenar el repo
*.jpg
*.jpeg
*.png
*.mp4
# Excepción: imágenes de la interfaz (iconos, logos)
!frontend/assets/
