# Copia este archivo como .env y rellena tus valores.
# NUNCA subas .env al repo (ya está en .gitignore).

# --- IA ---
WANDB_API_KEY=...          # Weights & Biases — necesario para logging del entrenamiento
LANGFUSE_PUBLIC_KEY=...    # Langfuse — trazabilidad de llamadas al agente
LANGFUSE_SECRET_KEY=...
GEMINI_API_KEY=...         # Google Gemini — generación del certificado

# --- Backend ---
SUPABASE_URL=...           # URL del proyecto Supabase
SUPABASE_KEY=...           # service_role key (no exponerla en el frontend)

# --- Rutas del modelo ---
MODEL_PATH=ai/weights/best.pt   # Ruta al peso entrenado (lo consume el Backend)
